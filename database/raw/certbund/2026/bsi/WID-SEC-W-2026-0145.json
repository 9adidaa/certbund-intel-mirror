      {
        "category": "description",
        "text": "FreeRDP ist eine freie Implementierung des Remote Desktop Protocol (RDP).",
        "title": "Produktbeschreibung"
      },
      {
        "category": "summary",
        "text": "Ein entfernter, anonymer Angreifer kann mehrere Schwachstellen in FreeRDP ausnutzen, um einen Denial-of-Service-Zustand zu verursachen oder möglicherweise beliebigen Code auszuführen.",
        "title": "Angriff"
      },
