      {
        "category": "description",
        "text": "Vim (Vi IMproved) ist eine Weiterentwicklung des Texteditors vi.",
        "title": "Produktbeschreibung"
      },
      {
        "category": "summary",
        "text": "Ein lokaler Angreifer kann mehrere Schwachstellen in vim ausnutzen, um beliebigen Code auszuführen, einen Denial-of-Service-Zustand zu verursachen oder Daten zu manipulieren.",
        "title": "Angriff"
      },
